# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Internal workspace for private docs/automation
.internal/
.internal-backup/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Env / secrets
.env
.env.*
*.local
auth.json

# LocalWP
/app/sql/
/app/public/wp-config.php
/local-lightning/
/Local Sites/

# Ignore all WordPress content by default...
/app/public/wp-content/*

# ...but keep these tracked
!/app/public/wp-content/themes/
!/app/public/wp-content/themes/chama-inn/
!/app/public/wp-content/themes/chama-inn/**

!/app/public/wp-content/plugins/
!/app/public/wp-content/plugins/chama-core/
!/app/public/wp-content/plugins/chama-core/**

!/app/public/wp-content/plugins/chama-ops/
!/app/public/wp-content/plugins/chama-ops/**

!/app/public/wp-content/plugins/chama-pwa/
!/app/public/wp-content/plugins/chama-pwa/**

!/app/public/wp-content/mu-plugins/
!/app/public/wp-content/mu-plugins/**

# Ignore uploads and generated/cache content
/app/public/wp-content/uploads/
/app/public/wp-content/cache/
/app/public/wp-content/upgrade/
/app/public/wp-content/backups/
/app/public/wp-content/ai1wm-backups/
/app/public/wp-content/wflogs/

# Ignore bundled / third-party plugins and themes you install through WP admin
/app/public/wp-content/plugins/*
!/app/public/wp-content/plugins/chama-core/
!/app/public/wp-content/plugins/chama-core/**
!/app/public/wp-content/plugins/chama-ops/
!/app/public/wp-content/plugins/chama-ops/**
!/app/public/wp-content/plugins/chama-pwa/
!/app/public/wp-content/plugins/chama-pwa/**
!/app/public/wp-content/mu-plugins/
!/app/public/wp-content/mu-plugins/**

/app/public/wp-content/themes/*
!/app/public/wp-content/themes/chama-inn/
!/app/public/wp-content/themes/chama-inn/**

# Node / frontend build
node_modules/
dist/
build/
coverage/

# Composer / PHP deps
/vendor/

# Archives / database dumps
*.zip
*.tar.gz
*.sql
*.sqlite
*.bak

# Misc generated files
*.tmp
*.cache

# Notebook artifacts
**/.ipynb_checkpoints/
